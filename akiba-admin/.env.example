# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL — safe to expose client-side
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service role key — server-side only (API routes). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Raffle contract ─────────────────────────────────────────────────────────
# RaffleManager contract address on Celo. Falls back to hardcoded address if unset.
NEXT_PUBLIC_RAFFLE_MANAGER=0xYourRaffleManagerAddress

# ─── Telegram notifications ──────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Chat/channel ID to post raffle announcements (use one or both)
TELEGRAM_ANNOUNCE_CHAT_ID=-100your_announce_channel_id
TELEGRAM_ADMIN_CHAT_ID=-100your_admin_chat_id

# ─── Subgraphs ───────────────────────────────────────────────────────────────
# Games subgraph for dice daily active players and top winners charts.
# If unset, those charts show a "Subgraph not configured" banner.
GAMES_SUBGRAPH_URL=https://api.studio.thegraph.com/query/YOUR_ID/akiba-games/version/latest

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of the Akiba app (used in Telegram announcement links)
APP_URL=https://app.akibamiles.xyz
